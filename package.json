{
  "name": "bao-browser-m0",
  "version": "0.1.0",
  "private": true,
  "description": "Record + deterministic replay spike — single page, no LLM, no backend.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "test": "node build.mjs && node test/all.mjs",
    "test:assert": "node build.mjs && node test/assert.mjs",
    "test:download": "node build.mjs && node test/download.mjs",
    "test:grounding": "node build.mjs && node test/grounding.mjs",
    "test:golden": "node build.mjs && node test/golden.mjs",
    "test:check": "node build.mjs && node test/check.mjs",
    "test:keyboard": "node build.mjs && node test/keyboard.mjs",
    "test:pointerdown": "node build.mjs && node test/pointerdown.mjs",
    "test:editable": "node build.mjs && node test/editable.mjs",
    "test:spa": "node build.mjs && node test/spa.mjs",
    "test:nav": "node build.mjs && node test/nav.mjs",
    "test:list": "node build.mjs && node test/list.mjs",
    "test:blindspots": "node build.mjs && node test/blindspots.mjs",
    "test:virtual": "node build.mjs && node test/virtual.mjs",
    "test:frames": "node build.mjs && node test/frames.mjs",
    "test:forceopen": "node build.mjs && node test/forceopen.mjs",
    "test:live": "node build.mjs && node test/live-blindspots-open-shadow.mjs && node test/live-blindspots-canvas.mjs && node test/live-blindspots-frames.mjs && node test/live-blindspots-virtual.mjs && node test/live-blindspots-closed-shadow.mjs",
    "test:live:open-shadow": "node build.mjs && node test/live-blindspots-open-shadow.mjs",
    "test:live:canvas": "node build.mjs && node test/live-blindspots-canvas.mjs",
    "test:live:frames": "node build.mjs && node test/live-blindspots-frames.mjs",
    "test:live:virtual": "node build.mjs && node test/live-blindspots-virtual.mjs",
    "test:live:closed-shadow": "node build.mjs && node test/live-blindspots-closed-shadow.mjs",
    "test:live-gaps": "node build.mjs && node test/live-gaps-forms.mjs && node test/live-gaps-spa.mjs && node test/live-gaps-editors.mjs && node test/live-gaps-feed.mjs",
    "test:live-gaps:forms": "node build.mjs && node test/live-gaps-forms.mjs",
    "test:live-gaps:spa": "node build.mjs && node test/live-gaps-spa.mjs",
    "test:live-gaps:editors": "node build.mjs && node test/live-gaps-editors.mjs",
    "test:live-gaps:feed": "node build.mjs && node test/live-gaps-feed.mjs",
    "probe": "node build.mjs && node test/probe-sites.mjs",
    "build": "node build.mjs",
    "package": "node build.mjs && rm -f bao.zip && zip -r bao.zip manifest.json dist/ sidepanel.html dashboard.html icons/icon-16.png icons/icon-32.png icons/icon-48.png icons/icon-128.png",
    "icons": "node assets/gen-icons.mjs",
    "promo": "node assets/gen-promo.mjs",
    "screenshots": "node build.mjs && node assets/gen-screenshots.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test:snapshot": "node build.mjs && node test/snapshot.mjs",
    "test:sensitive": "node build.mjs && node test/sensitive.mjs",
    "test:workflows": "node build.mjs && node test/workflows.mjs",
    "test:params": "node build.mjs && node test/params.mjs",
    "test:sidepanel": "node build.mjs && node test/sidepanel.mjs",
    "test:dashboard": "node build.mjs && node test/dashboard.mjs"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "esbuild": "^0.28.1",
    "playwright": "^1.49.0",
    "typescript": "^6.0.3"
  }
}
