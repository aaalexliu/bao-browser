{
  "manifest_version": 3,
  "name": "Bao M0 Spike",
  "version": "0.0.1",
  "description": "Record + deterministic replay spike — single page, no LLM, no backend.",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation", "alarms", "downloads"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "dist/background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ]
}
